# Access control. Set to require a deployment-level password.
ACCESS_PASSWORD=""

# Multi-user accounts (optional). Setting DATABASE_URL enables email/password
# accounts, per-user sessions, and daily request quotas on top of the
# ACCESS_PASSWORD gate above. Leave DATABASE_URL empty to keep the deployment
# fully local-first with no account system. Chat history and knowledge stay
# client-side either way; only account records, quota counters, and audit
# logs live in this database. There is no admin UI for this data — manage
# quotas, disable accounts, or bump tokenVersion by editing rows directly.
DATABASE_URL=""
# Required when DATABASE_URL is set. Signs per-user session cookies. Generate
# with `openssl rand -base64 32`.
ACCOUNT_SESSION_SECRET=""
# Default daily request quota per user when a user's `dailyQuota` column is
# null. Counts requests to metered AI routes (chat, search, rag, voice,
# doc-parse), not tokens.
DEFAULT_DAILY_QUOTA="200"

# BYOK server key. Required in production unless BYOK_ALLOW_EPHEMERAL_KEY=true.
# Docker Compose defaults BYOK_ALLOW_EPHEMERAL_KEY to true for local smoke tests;
# production Docker and Cloudflare Workers should use a stable private key.
# IMPORTANT for serverless platforms (Vercel, Cloudflare Workers, etc.): each
# cold start / concurrent instance that relies on BYOK_ALLOW_EPHEMERAL_KEY
# generates its OWN keypair in memory, since nothing is shared across
# instances. A client-encrypted secret wrapped against one instance's public
# key will fail to decrypt on another, which shows up as intermittent
# "works sometimes" BYOK/API-proof failures. Always set a stable
# BYOK_PRIVATE_KEY_PEM (generate one with `pnpm byok:generate`) before
# deploying to Vercel or any multi-instance hosted environment.
BYOK_PRIVATE_KEY_PEM=""
BYOK_KEY_ID=""
BYOK_ALLOW_EPHEMERAL_KEY="false"

# Deployment safety. local allows local/private proxy endpoints; hosted blocks them by default.
# Cloudflare Workers should run in hosted mode and use public HTTPS upstreams.
DEPLOYMENT_MODE="local"
ALLOW_LOCAL_NETWORK_PROXY=""
# Allow user-configured custom provider base URLs while running in hosted mode.
# Off by default so hosted deployments pin providers to their official upstreams.
# Set to true for a self-hosted deployment that keeps hosted-mode protections
# (request proof, access control, SSRF checks) but needs to point models at
# custom or relay OpenAI-compatible endpoints. Public HTTPS only; localhost and
# private networks stay blocked. Ignored in local mode (custom URLs always allowed).
ALLOW_CUSTOM_PROVIDER_BASE_URL=""
# Trust x-forwarded-* and related proxy headers only when your platform strips spoofed values.
TRUST_PROXY_HEADERS="false"

# Optional in local mode, required in hosted mode UNLESS ALLOW_MEMORY_STORE_FALLBACK=true.
# Set to true for a single-instance self-hosted deployment (e.g. a personal Vercel
# project) that runs in hosted mode but does not want to provision Upstash/Redis.
# This lets rate limiting, document parse jobs, and the plugin registry fall back to
# per-instance in-memory storage. WARNING: in-memory stores are NOT shared across
# serverless instances. If your deployment scales beyond one instance, rate limiting
# weakens and document parse polling can miss jobs created on another instance. Leave
# empty/false and configure Upstash for multi-instance hosted deployments.
ALLOW_MEMORY_STORE_FALLBACK=""

# RATE_LIMIT_STORE, DOCUMENT_PARSE_JOB_STORE, and PLUGIN_REGISTRY_STORE support memory or upstash.
# Hosted and multi-instance deployments should use upstash for all three stores.
RATE_LIMIT_STORE="memory"
DOCUMENT_PARSE_JOB_STORE="memory"
PLUGIN_REGISTRY_STORE="memory"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Upload limits. Values are bytes.
MAX_ATTACHMENT_FILE_BYTES="10485760"

# Public URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL=""

# Server default model provider.
DEFAULT_PROVIDER_TYPE="Gemini"
DEFAULT_PROVIDER_NAME="Default"
DEFAULT_PROVIDER_BASE_URL=""
DEFAULT_PROVIDER_API_KEY=""
DEFAULT_PROVIDER_MODELS=""

# Default task models.
DEFAULT_MODEL_TITLE_GENERATION=""
DEFAULT_MODEL_RELATED_QUESTIONS=""
DEFAULT_MODEL_CONTEXT_COMPRESSION=""
DEFAULT_MODEL_PROMPT_OPTIMIZATION=""
DEFAULT_MODEL_RAG_QUERY=""
DEFAULT_MODEL_MEMORY=""

# Default search provider: tavily, firecrawl, exa, bocha, or searxng.
DEFAULT_SEARCH_PROVIDER=""
DEFAULT_SEARCH_API_KEY=""
DEFAULT_SEARCH_BASE_URL=""

# Default RAG/vector store and document processing.
DEFAULT_RAG_BASE_URL=""
DEFAULT_RAG_TOKEN=""
DEFAULT_RAG_TOP_K="10"
DEFAULT_RAG_CHUNK_SIZE="512"
DEFAULT_RAG_NAMESPACE="default"
DEFAULT_DOCUMENT_PARSE_PROVIDER="mineru"
DEFAULT_MINERU_API_TOKEN=""
DEFAULT_LLAMA_PARSE_API_KEY=""

# Default voice provider settings.
DEFAULT_VOICE_PROVIDER=""
DEFAULT_ELEVENLABS_API_KEY=""
DEFAULT_ELEVENLABS_STT_MODEL="scribe_v2"
DEFAULT_ELEVENLABS_TTS_MODEL="eleven_flash_v2_5"
DEFAULT_ELEVENLABS_TTS_VOICE_ID="bIHbv24MWmeRgasZH58o"
DEFAULT_MIMO_API_KEY=""
DEFAULT_MIMO_STT_MODEL="mimo-v2.5-asr"
DEFAULT_MIMO_TTS_MODEL="mimo-v2.5-tts"
DEFAULT_MIMO_TTS_VOICE_ID="mimo_default"

# Default system behavior.
DEFAULT_SYSTEM_PROMPT=""
DEFAULT_ENABLE_AUTO_TITLE="true"
DEFAULT_ENABLE_RELATED_QUESTIONS="true"
DEFAULT_ENABLE_AUTO_COMPRESSION="true"
DEFAULT_COMPRESSION_THRESHOLD="12"
DEFAULT_HISTORY_KEEP_COUNT="4"
DEFAULT_ENABLE_CODE_COLLAPSE="true"
DEFAULT_ENABLE_HTML_VISUAL_PROMPT="true"
